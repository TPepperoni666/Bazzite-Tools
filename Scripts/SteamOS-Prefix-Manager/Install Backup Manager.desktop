[Desktop Entry]
Name=Install Backup Manager
Comment=Install SteamOS Backup Manager
Exec=konsole -e bash -c 'mkdir -p "$HOME/scripts" && echo  | base64 -d > "$HOME/scripts/steamos_manager.sh" && chmod +x "$HOME/scripts/steamos_manager.sh" && rm -f "$HOME/Desktop/Install Backup Manager.desktop" && exec bash "$HOME/scripts/steamos_manager.sh"'
Icon=utilities-terminal
Terminal=false
Type=Application
Categories=Utility;
